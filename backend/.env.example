OPENAI_API_KEY=your_openai_api_key
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=your_long_lived_access_token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
OPENWEATHER_API_KEY=your_openweathermap_api_key
GOOGLE_APPLICATION_CREDENTIALS=your_google_application_credentials
GOOGLE_API_KEY=your_google_api_key
GOOGLE_MODEL_NAME=your_google_model_name
# RAG / Knowledge Base
LLAMA_PARSE_API_KEY=your_llamacloud_api_key
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id
CHROMA_DB_PATH=./chroma_db
# Supabase PostgreSQL with transaction pooler (port 6543)
# Format: postgresql+asyncpg://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?prepared_statement_cache_size=0
DATABASE_URL=postgresql+asyncpg://postgres.your-project-ref:your-password@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?prepared_statement_cache_size=0
